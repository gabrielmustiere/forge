# Copiez ce fichier en `.env.local` et renseignez les valeurs réelles (jamais commité).

###> symfony/framework-bundle ###
APP_ENV=dev
# Requis : sert de graine à la dérivation de clé (HKDF) du chiffrement des tokens de projet.
# Une valeur vide fait échouer le chiffrement (App\Service\TokenCipher).
APP_SECRET=
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=smtp://localhost:1027
###< symfony/mailer ###

# Reader de dépôt factice (dev uniquement) : 1 = stories déterministes sans réseau (E2E board).
APP_FAKE_REPOSITORY_READER=0

###> forge/interview (story 009) ###
# Exécution du skill feature-interview en headless (ADR-0002).
# V1 locale : session « claude » ambiante (OAuth ~/.claude), pas de clé API.
# ANTHROPIC_API_KEY = mode serveur (--bare) — déféré (suite ADR-0002), non requis en local.
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-haiku-4-5
# Liste blanche d'outils du skill (CSV) : borne la surface d'exécution de l'agent.
CLAUDE_ALLOWED_TOOLS=Read,Write,Glob,Grep,Bash
###< forge/interview (story 009) ###
