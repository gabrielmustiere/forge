{% extends 'security.html.twig' %}

{% block title %}Se connecter · Forge Board{% endblock %}

{% block body %}
    <div class="w-full max-w-sm">
        {# Marque #}
        <div class="mb-7 flex flex-col items-center gap-3 text-center">
            <span class="grid size-11 place-items-center rounded-xl bg-gradient-to-br from-iris-bright to-iris-deep text-lg font-bold text-white">F</span>
            <div>
                <h1 class="text-[22px] font-bold tracking-tight text-ink-bright">Se connecter</h1>
                <p class="mt-1 text-sm text-ink-dim">Accédez à vos projets et tableaux Forge Board.</p>
            </div>
        </div>

        <form method="post" data-test="login-form"
              class="rounded-xl border border-line-strong bg-surface p-6 shadow-xl shadow-black/20">

            {% if error %}
                {# Message volontairement neutre : n'indique jamais quel champ est en cause (pitch, règle métier 4). #}
                <div data-test="login-error" role="alert"
                     class="mb-5 flex items-start gap-2.5 rounded-lg border border-danger-subtle bg-danger-soft px-3.5 py-2.5 text-[13px] text-fg-danger-strong">
                    <twig:ux:icon name="tabler:alert-triangle" class="mt-px size-4 shrink-0"/>
                    <span>Identifiants invalides.</span>
                </div>
            {% endif %}

            <div class="space-y-4">
                <div>
                    <label for="username" class="mb-1.5 block text-[13px] font-medium text-ink-soft">Adresse e-mail</label>
                    <input type="email" id="username" name="_username" value="{{ last_username }}"
                           autocomplete="email" required autofocus
                           data-test="login-email"
                           placeholder="admin@example.com"
                           class="block w-full rounded-lg border border-line-strong bg-input px-3.5 py-2.5 text-sm text-ink placeholder:text-ink-faint focus:border-iris focus:outline-none focus:ring-1 focus:ring-iris">
                </div>

                <div>
                    <label for="password" class="mb-1.5 block text-[13px] font-medium text-ink-soft">Mot de passe</label>
                    <input type="password" id="password" name="_password"
                           autocomplete="current-password" required
                           data-test="login-password"
                           placeholder="••••••••"
                           class="block w-full rounded-lg border border-line-strong bg-input px-3.5 py-2.5 text-sm text-ink placeholder:text-ink-faint focus:border-iris focus:outline-none focus:ring-1 focus:ring-iris">
                </div>

                <label class="flex items-center gap-2.5 text-[13px] text-ink-dim">
                    <input type="checkbox" name="_remember_me" value="on"
                           data-test="login-remember"
                           class="size-4 rounded border-line-strong bg-input text-iris focus:ring-1 focus:ring-iris focus:ring-offset-0">
                    Rester connecté
                </label>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" data-test="login-submit"
                    class="mt-6 flex w-full items-center justify-center gap-2 rounded-lg bg-iris px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-iris-bright focus:outline-none focus:ring-2 focus:ring-iris/50">
                <twig:ux:icon name="tabler:login" class="size-4"/> Se connecter
            </button>
        </form>
    </div>
{% endblock %}
