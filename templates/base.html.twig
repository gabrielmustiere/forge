<!DOCTYPE html>
<html lang="fr" class="dark h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Forge Board{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><defs><linearGradient id=%22g%22 x1=%220%22 y1=%220%22 x2=%221%22 y2=%221%22><stop offset=%220%22 stop-color=%22%238b7bf5%22/><stop offset=%221%22 stop-color=%22%235b4bd6%22/></linearGradient></defs><rect width=%22128%22 height=%22128%22 rx=%2230%22 fill=%22url(%23g)%22/><text y=%221.02em%22 x=%220.5em%22 text-anchor=%22middle%22 font-family=%22sans-serif%22 font-size=%2280%22 font-weight=%22700%22 fill=%22%23ffffff%22>F</text></svg>">
    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="antialiased bg-canvas text-ink font-sans h-full">

{% set route = app.request.attributes.get('_route') %}

{# Topbar — mobile uniquement #}
<nav class="fixed inset-x-0 top-0 z-50 flex h-12 items-center justify-between border-b border-line bg-surface px-3 md:hidden">
    <div class="flex items-center gap-2">
        <button data-drawer-target="nova-sidebar" data-drawer-toggle="nova-sidebar"
                aria-controls="nova-sidebar" type="button"
                class="grid size-8 place-items-center rounded-md text-ink-dim hover:bg-raised hover:text-ink">
            <twig:ux:icon name="tabler:menu-2" class="size-5"/>
            <span class="sr-only">Ouvrir le menu</span>
        </button>
        <a href="{{ path('app_page') }}" class="flex items-center gap-2">
            <span class="grid size-6 place-items-center rounded-md bg-gradient-to-br from-iris-bright to-iris-deep text-2xs font-bold text-white">F</span>
            <span class="text-sm font-semibold text-ink">Forge Board</span>
        </a>
    </div>
    {% if app.user %}
        <span class="grid size-7 place-items-center rounded-full bg-iris text-2xs font-semibold text-white">
            {{ app.user.userIdentifier|first|upper }}
        </span>
    {% endif %}
</nav>

{# Sidebar #}
<aside id="nova-sidebar"
       class="fixed top-0 left-0 z-40 flex h-screen w-[230px] -translate-x-full flex-col border-r border-line bg-surface py-2.5 transition-transform md:translate-x-0"
       aria-label="Sidebar">

    {# Marque #}
    <div class="flex items-center gap-2.5 px-4 pb-3.5 pt-1.5">
        <span class="grid size-[22px] place-items-center rounded-md bg-gradient-to-br from-iris-bright to-iris-deep text-2xs font-bold text-white">F</span>
        <span class="flex-1 text-sm font-semibold text-ink">Forge Board</span>
        <span class="font-mono text-2xs text-ink-faint">v4.1</span>
    </div>

    {# Navigation principale #}
    {% set nav = [
        { route: 'app_page', label: 'Tableau de bord', icon: 'tabler:layout-dashboard' },
        { route: 'app_design_system', label: 'Design System', icon: 'tabler:palette' }
    ] %}
    <nav class="flex flex-col gap-px px-2">
        {% for item in nav %}
            {% set active = route == item.route %}
            <a href="{{ path(item.route) }}"
               class="group flex items-center gap-2.5 rounded-md px-2 py-1.5 text-[13px] {{ active ? 'bg-iris/12 font-medium text-ink' : 'text-ink-dim hover:bg-raised hover:text-ink' }}">
                <twig:ux:icon name="{{ item.icon }}" class="size-[15px] {{ active ? 'text-iris-bright' : 'text-ink-subtle group-hover:text-ink-dim' }}"/>
                <span>{{ item.label }}</span>
            </a>
        {% endfor %}
    </nav>

    {# Projets (scan docs/story/ — à venir) #}
    <div class="px-4 pb-2 pt-5 text-[11px] font-semibold uppercase tracking-wide text-ink-faint">Projets</div>
    <div class="px-3 text-[12px] leading-relaxed text-ink-muted">
        <span class="font-mono text-ink-subtle">docs/story/</span> — scan à venir.
    </div>

    {# Footer utilisateur #}
    <div class="mt-auto border-t border-line px-3.5 pb-1 pt-2.5">
        {% if app.user %}
            <div class="flex items-center gap-2.5">
                <span class="grid size-6 place-items-center rounded-full bg-iris text-2xs font-semibold text-white">
                    {{ app.user.userIdentifier|first|upper }}
                </span>
                <span class="min-w-0 flex-1 truncate text-[12.5px] text-ink-soft">{{ app.user.userIdentifier }}</span>
                <a href="{{ path('app_logout') }}" title="Déconnexion" data-test="logout"
                   class="grid size-6 place-items-center rounded-md text-ink-faint hover:bg-raised hover:text-ink-dim">
                    <twig:ux:icon name="tabler:logout" class="size-4"/>
                </a>
            </div>
        {% else %}
            <a href="{{ path('app_login') }}"
               class="flex items-center justify-center gap-2 rounded-md bg-iris px-3 py-1.5 text-[13px] font-semibold text-white hover:bg-iris-bright">
                <twig:ux:icon name="tabler:login" class="size-4"/> Se connecter
            </a>
        {% endif %}
    </div>
</aside>

<main class="h-full min-h-screen pt-12 md:ml-[230px] md:pt-0">
    {% block body %}{% endblock %}
</main>

{% include 'common/flash-messages.html.twig' %}

</body>
</html>
