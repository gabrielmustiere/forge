{#
    Badge de statut générique. Attend :
      - status    : enum exposant value/label/badgeTone/icon (VerificationStatus, CloneStatus…)
      - testId    : valeur du `data-test` (défaut 'project-status')
      - iconClass : classes additionnelles sur l'icône (défaut '', ex. 'animate-spin' pendant un clonage)
#}
{% set tones = {
    ok: 'bg-success-soft text-fg-success-strong border-success-subtle',
    warning: 'bg-warning-soft text-fg-warning border-warning-subtle',
    danger: 'bg-danger-soft text-fg-danger-strong border-danger-subtle',
    neutral: 'bg-raised text-ink-dim border-line-strong',
} %}
<span data-test="{{ testId|default('project-status') }}" data-status="{{ status.value }}"
      class="inline-flex items-center gap-1.5 rounded-md border px-2 py-0.5 text-[12px] font-medium {{ tones[status.badgeTone] }}">
    <twig:ux:icon name="{{ status.icon }}" class="size-3.5 {{ iconClass|default('') }}"/> {{ status.label }}
</span>
