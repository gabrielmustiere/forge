{% extends 'base.html.twig' %}

{% block title %}{{ project.name }} · Forge Board{% endblock %}

{% block body %}
    <div class="flex h-full flex-col">
    <header class="flex h-12 shrink-0 items-center gap-4 border-b border-line bg-surface px-5">
        {# Fil d'ariane + identité du projet #}
        <div class="flex min-w-0 items-center gap-2.5 text-[13px]">
            <span class="shrink-0 text-ink-muted">Forge Board</span>
            <span class="shrink-0 text-divider">/</span>
            <a href="{{ path('app_project_index') }}" class="shrink-0 text-ink-muted hover:text-ink">Projets</a>
            <span class="shrink-0 text-divider">/</span>
            <h1 class="truncate font-medium text-ink">{{ project.name }}</h1>
            <a href="{{ project.url }}" target="_blank" rel="noopener noreferrer" data-test="project-repo-link"
               class="inline-flex shrink-0 items-center gap-1.5 rounded-md bg-raised px-2 py-1 text-[12px] font-medium text-ink-dim hover:bg-stat hover:text-ink">
                <twig:ux:icon name="{{ project.provider.icon }}" class="size-3.5"/> {{ project.provider.label }}
                <twig:ux:icon name="tabler:external-link" class="size-3.5 text-ink-faint"/>
            </a>
            {{ include('project/_status_badge.html.twig', { status: project.verificationStatus }) }}
        </div>

        {# Métadonnées + actions #}
        <div class="ml-auto flex shrink-0 items-center gap-3">
            <span class="hidden items-center gap-1.5 text-[12px] text-ink-faint xl:inline-flex">
                <twig:ux:icon name="tabler:calendar-plus" class="size-3.5"/>
                <span class="font-mono text-ink-dim">{{ project.createdAt|date('d/m/Y') }}</span>
            </span>
            <span class="hidden items-center gap-1.5 text-[12px] text-ink-faint xl:inline-flex" data-test="project-verified-at">
                <twig:ux:icon name="tabler:refresh" class="size-3.5"/>
                <span class="font-mono text-ink-dim">{{ project.verifiedAt ? project.verifiedAt|date('d/m/Y à H:i') : 'Jamais' }}</span>
            </span>
            <span class="hidden h-5 w-px bg-line xl:block"></span>
            <twig:ProjectCloneStatus :project="project"/>
            {% if project.isCloned %}
                <a href="{{ path('app_project_interview', { id: project.id }) }}" data-test="project-interview"
                   class="flex h-7 items-center gap-1.5 rounded-md bg-iris px-2.5 text-[12.5px] font-semibold text-white hover:bg-iris-bright">
                    <twig:ux:icon name="tabler:message-plus" class="size-3.5"/> Exprimer un besoin
                </a>
            {% else %}
                <button type="button" disabled data-test="project-interview" title="Clonez d'abord le dépôt pour exprimer un besoin"
                        class="flex h-7 cursor-not-allowed items-center gap-1.5 rounded-md border border-line-strong px-2.5 text-[12.5px] text-ink-faint opacity-50">
                    <twig:ux:icon name="tabler:message-plus" class="size-3.5"/> Exprimer un besoin
                </button>
            {% endif %}
            <form method="post" action="{{ path('app_project_verify', { id: project.id }) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('verify' ~ project.id) }}">
                <button type="submit" data-test="project-verify"
                        class="flex h-7 items-center gap-1.5 rounded-md border border-line-strong px-2.5 text-[12.5px] text-ink-dim hover:bg-raised hover:text-ink">
                    <twig:ux:icon name="tabler:refresh" class="size-3.5"/> Vérifier l'accès
                </button>
            </form>
            <a href="{{ path('app_project_edit', { id: project.id }) }}" data-test="project-edit"
               class="flex h-7 items-center gap-1.5 rounded-md border border-line-strong px-2.5 text-[12.5px] text-ink-dim hover:bg-raised hover:text-ink">
                <twig:ux:icon name="tabler:edit" class="size-3.5"/> Modifier
            </a>
        </div>
    </header>

    <div data-test="project-detail" class="flex min-h-0 flex-1 flex-col">
        {# Kanban : scan live du dépôt projeté en colonnes + drawer d'ouverture de document #}
        <div data-controller="story-drawer" data-test="project-board" class="flex min-h-0 flex-1 flex-col">
            {{ include('project/_board.html.twig', { result: result, project: project }) }}
            {{ include('project/_drawer.html.twig') }}
        </div>
    </div>
    </div>
{% endblock %}
