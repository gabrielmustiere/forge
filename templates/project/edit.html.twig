{% extends 'base.html.twig' %}

{% block title %}Modifier {{ project.name }} · Forge Board{% endblock %}

{% block body %}
    <header class="flex h-12 items-center justify-between border-b border-line bg-surface px-5">
        <div class="flex items-center gap-2 text-[13px]">
            <span class="text-ink-muted">Forge Board</span>
            <span class="text-divider">/</span>
            <a href="{{ path('app_project_index') }}" class="text-ink-muted hover:text-ink">Projets</a>
            <span class="text-divider">/</span>
            <span class="font-medium text-ink">Modifier</span>
        </div>
    </header>

    <div class="p-6">
        <div class="mx-auto max-w-xl">
            <div class="mb-6">
                <h1 class="text-[22px] font-bold tracking-tight text-ink-bright">Modifier le projet</h1>
                <p class="mt-1 font-mono text-sm text-ink-dim">{{ project.name }}</p>
            </div>

            <div class="rounded-xl border border-line-strong bg-surface p-6 shadow-xl shadow-black/20">
                {% include 'project/_form.html.twig' with {
                    submit_label: 'Enregistrer les modifications',
                    token_placeholder: '••••••••  (inchangé)',
                    token_hint: 'Laissez vide pour conserver le token actuel ; saisissez une nouvelle valeur pour le renouveler.',
                } %}
            </div>
        </div>
    </div>
{% endblock %}
